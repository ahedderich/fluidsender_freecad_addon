# =============================================================================
# FluidSender — .gitignore
# Covers: Nuxt 3 / Bun, Rust, Docker, editors, OS artefacts
# =============================================================================

docker-compose.claude.yaml

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# -----------------------------------------------------------------------------
# Nuxt 3 (ui/ and fluid-sim/sim-ui/)
# -----------------------------------------------------------------------------
.nuxt/
.output/
.nitro/
.cache/
dist/
.data/

# Nuxt dev server state
*.nuxt-devtools*

# Nuxt CLI local setup marker (@nuxt/test-utils etc.)
.nuxtrc

# -----------------------------------------------------------------------------
# Bun / Node
# -----------------------------------------------------------------------------
node_modules/
.bun/

# Bun lock file is committed for reproducible installs
# bun.lockb  ← do NOT ignore

# Build artefacts
build/
.svelte-kit/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Python (freecad_addon/ FreeCAD CAM addon)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# -----------------------------------------------------------------------------
# Test & coverage
# -----------------------------------------------------------------------------
coverage/
.vitest/
vitest.results.json
htmlcov/
.nyc_output/
.playwright-cli/
ui/.test-out
ui/.test-out-probing

# -----------------------------------------------------------------------------
# Rust (fluid-sim/sim/)
# -----------------------------------------------------------------------------
target/
# Cargo.lock is committed for binary crates (the simulator is a binary)
# Cargo.lock  ← do NOT ignore

# Rustfmt backup files
**/*.rs.bk

# Rust perf/profiling artefacts
perf.data
perf.data.old
flamegraph.svg
massif.out.*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Local override files (machine-specific port/volume tweaks)
docker-compose.override.yaml
docker-compose.override.yml

# Trivy scan reports (generated locally; not committed)
trivy-results*.json
trivy-results*.sarif

# -----------------------------------------------------------------------------
# Persistent volume directories (config & data)
# Runtime-populated; .gitkeep files keep the directories tracked
# -----------------------------------------------------------------------------
ui/config/*
!ui/config/.gitkeep
!ui/config/*.example.yaml
!ui/config/*.example.toml

ui/data/*
!ui/data/.gitkeep

fluid-sim/sim-ui/config/*
!fluid-sim/sim-ui/config/.gitkeep
!fluid-sim/sim-ui/config/*.example.yaml
!fluid-sim/sim-ui/config/*.example.toml

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-error.log*

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
# VS Code — keep shared settings, ignore personal/machine-specific files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains (IntelliJ, CLion, WebStorm, RustRover)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist
tags

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace

# -----------------------------------------------------------------------------
# Reference repositories (cloned locally for firmware behaviour research)
# Clone with: git clone <url> <repo-name>/ inside this folder
# -----------------------------------------------------------------------------
FluidNC/

# -----------------------------------------------------------------------------
# Temporary & misc
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.patch
*.rej

# -----------------------------------------------------------------------------
# Un-ignore rules (must stay at the end -- gitignore uses last-match-wins)
# -----------------------------------------------------------------------------
# The macOS "Icon?" rule above (for the special per-folder custom-icon file)
# also matches this FreeCAD addon's real Resources/icons/ directory
# case-insensitively (core.ignorecase) -- explicitly keep it.
!Resources/
!Resources/**
.scratch/
scratch/
TODO.local.md
